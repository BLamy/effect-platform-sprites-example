{
  "name": "effect-platform-sprites-example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare:almostnode": "node scripts/prepare-almostnode-assets.mjs",
    "predev": "npm run prepare:almostnode",
    "dev": "EFFECT_DEVTOOLS=true next dev --turbopack",
    "prebuild": "npm run prepare:almostnode",
    "build": "next build",
    "start": "EFFECT_DEVTOOLS=true next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "almostnode:sandbox": "npm run prepare:almostnode && npx vite public/almostnode-sandbox --host 127.0.0.1 --port 3002",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@effect/experimental": "^0.60.0",
    "@effect/language-service": "^0.86.1",
    "@effect/platform": "^0.96.1",
    "@fly/sprites": "^0.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@replayio/effect-platform-sprites": "https://pkg.pr.new/BLamy/effect-platform-sprites/@replayio/effect-platform-sprites@ea4fdc4",
    "@supabase/supabase-js": "^2.106.0",
    "almostnode": "^0.2.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.2",
    "lucide-react": "^1.16.0",
    "monaco-editor": "^0.55.1",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BLamy/effect-platform-sprites-example.git"
  },
  "bugs": {
    "url": "https://github.com/BLamy/effect-platform-sprites-example/issues"
  },
  "homepage": "https://github.com/BLamy/effect-platform-sprites-example#readme",
  "license": "ISC"
}
